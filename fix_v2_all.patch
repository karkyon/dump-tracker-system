+// ── GPS ピン調整マップ（Google Maps API） ──
+const MAPS_API_KEY = 'AIzaSyCpQGN2eC7q0jE-wZdVO_NauO5_NgmVerk';
+
+interface GpsPinMapProps {
+  accentColor: string;
+  initialLat?: number;
+  initialLng?: number;
+  onPinMoved: (lat: number, lng: number) => void;
+}
+
+declare const google: any;
+
+const GpsPinMap: React.FC<GpsPinMapProps> = ({ accentColor, initialLat, initialLng, onPinMoved }) => {
+  const mapRef = useRef<HTMLDivElement>(null);
+  const mapInstanceRef = useRef<any>(null);
+  const markerRef = useRef<any>(null);
+  const [expanded, setExpanded] = useState(false);
+  const [isLoaded, setIsLoaded] = useState(false);
+
+  const defaultLat = initialLat ?? 34.6937;
+  const defaultLng = initialLng ?? 135.5023;
+
+  const initMap = useCallback(() => {
+    if (!mapRef.current || mapInstanceRef.current) return;
+    try {
+      const map = new google.maps.Map(mapRef.current, {
+        center: { lat: defaultLat, lng: defaultLng },
+        zoom: 17,
+        disableDefaultUI: true,
+        zoomControl: true,
+        gestureHandling: 'cooperative',
+      });
+
+      const marker = new google.maps.Marker({
+        position: { lat: defaultLat, lng: defaultLng },
+        map,
+        draggable: true,
+        title: 'ドラッグで位置を調整',
+        icon: {
+          path: google.maps.SymbolPath.CIRCLE,
+          scale: 10,
+          fillColor: accentColor,
+          fillOpacity: 1,
+          strokeColor: '#fff',
+          strokeWeight: 2,
+        },
+      });
+
+      marker.addListener('dragend', () => {
+        const pos = marker.getPosition();
+        if (pos) {
+          onPinMoved(pos.lat(), pos.lng());
+        }
+      });
+
+      map.addListener('click', (e: any) => {
+        marker.setPosition(e.latLng);
+        onPinMoved(e.latLng.lat(), e.latLng.lng());
+      });
+
+      mapInstanceRef.current = map;
+      markerRef.current = marker;
+      setIsLoaded(true);
+    } catch (err) {
+      console.error('Map init error:', err);
+    }
+  }, [defaultLat, defaultLng, accentColor, onPinMoved]);
+
+  useEffect(() => {
+    const tryInit = (): (() => void) | void => {
+      if (typeof google !== 'undefined' && google.maps) {
+        initMap();
+        return;
+      } else {
+        // Google Maps APIがまだロードされていない場合はスクリプトタグを確認
+        const existing = document.getElementById('gmap-script-edit');
+        if (!existing) {
+          const s = document.createElement('script');
+          s.id = 'gmap-script-edit';
+          s.src = `https://maps.googleapis.com/maps/api/js?key=${MAPS_API_KEY}&callback=__gmapEditReady`;
+          s.async = true;
+          (window as any).__gmapEditReady = () => initMap();
+          document.head.appendChild(s);
+          return;
+        } else {
+          // スクリプトは存在するが google がまだ未定義 → ポーリング
+          const t = setInterval(() => {
+            if (typeof google !== 'undefined' && google.maps) {
+              clearInterval(t);
+              initMap();
+            }
+          }, 200);
+          return () => clearInterval(t);
+        }
+      }
+    };
+    return tryInit() ?? undefined;
+  }, [initMap]);
+
+  // expanded 変更時にマップをリサイズ
+  useEffect(() => {
+    if (mapInstanceRef.current) {
+      setTimeout(() => {
+        google.maps.event.trigger(mapInstanceRef.current, 'resize');
+      }, 150);
+    }
+  }, [expanded]);
+
+  return (
+    <div>
+      <div style={{ fontSize: 10, color: '#6b7280', marginBottom: 3, fontWeight: 500, display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
+        <span>場所ピン調整<span style={{ fontSize: 9, color: '#9ca3af', fontWeight: 400 }}> — ドラッグで微調整</span></span>
+        <span
+          onClick={() => setExpanded(e => !e)}
+          style={{ fontSize: 9, color: accentColor, border: `0.5px solid ${accentColor}`, borderRadius: 4, padding: '1px 6px', cursor: 'pointer' }}
+        >
+          {expanded ? '縮小 ⊖' : '拡大 ⛶'}
+        </span>
       </div>
-      <div style={{ position: 'absolute', bottom: 5, left: '50%', transform: 'translateX(-50%)', background: 'rgba(0,0,0,0.52)', color: '#fff', fontSize: 9, padding: '2px 8px', borderRadius: 8, whiteSpace: 'nowrap' }}>ドラッグでピン移動</div>
-      <div style={{ position: 'absolute', top: 5, right: 5, background: 'rgba(255,255,255,0.88)', borderRadius: 5, padding: '2px 6px', fontSize: 9, color: '#333', border: '0.5px solid rgba(0,0,0,0.15)', cursor: 'pointer' }}>拡大 ⛶</div>
+      <div
+        ref={mapRef}
+        style={{
+          borderRadius: 7,
+          overflow: 'hidden',
+          height: expanded ? 220 : 100,
+          border: `0.5px solid ${accentColor}33`,
+          transition: 'height 0.25s ease',
+          background: '#e8f0e4',
+        }}
+      />
+      {!isLoaded && (
+        <div style={{ fontSize: 9, color: '#9ca3af', textAlign: 'center', marginTop: 3 }}>
+          地図を読み込み中...
+        </div>
